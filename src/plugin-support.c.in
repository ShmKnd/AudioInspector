#include "plugin-support.h"

/* These are generated/substituted by CMake when using the .in template */
const char *PLUGIN_NAME = "@CMAKE_PROJECT_NAME@";
const char *PLUGIN_VERSION = "@CMAKE_PROJECT_VERSION@";

/* Wrapper that prefixes the plugin name to the format string and forwards to libobs blogva */
void obs_log(int log_level, const char *format, ...)
{
	if (!format)
		return;

	/* Build template: "[<PLUGIN_NAME>] <format>" */
	size_t tpl_len = strlen(PLUGIN_NAME) + 3 + strlen(format) + 1; /* 3 = '[' + ']' + ' ' ; +1 for NUL */
	char *template = (char *)malloc(tpl_len);
	if (!template)
		return;

	/* snprintf with buffer size = tpl_len */
	snprintf(template, tpl_len, "[%s] %s", PLUGIN_NAME, format);

	va_list args;
	va_start(args, format);
	blogva(log_level, template, args);
	va_end(args);

	free(template);
}